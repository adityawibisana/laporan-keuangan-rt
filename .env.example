# ============================================================================
# Copy this file to `.env` and fill in your own values.
# After editing .env, do a FULL restart (not hot reload) for it to take effect.
# ============================================================================
#
# ----------------------------------------------------------------------------
# ONE-TIME GOOGLE CLOUD SETUP (only needed for the edit/sign-in feature;
# read-only viewing works without any of this)
# ----------------------------------------------------------------------------
# 1. console.cloud.google.com -> create or select a project.
# 2. APIs & Services -> Library -> enable "Google Sheets API".
# 3. OAuth consent screen -> User type "External":
#      - fill app name + support email
#      - Add scope:  https://www.googleapis.com/auth/spreadsheets
#      - Add Test users: the Google account(s) that will sign in
#        (while in "Testing" mode, only listed test users can sign in).
# 4. Credentials -> Create credentials -> OAuth client ID, create the ones you
#    need for your target platforms:
#      - Android: needs the app package name + signing SHA-1
#          package name: aditya.wibisana.rt3rw21
#          debug SHA-1 :  keytool -list -v \
#                           -keystore ~/.android/debug.keystore \
#                           -alias androiddebugkey -storepass android -keypass android
#      - iOS: needs the app bundle id.
#      - Web application: no redirect URIs needed; its Client ID is used as the
#          serverClientId on mobile (GOOGLE_SERVER_CLIENT_ID below).
#      - Desktop app: for editing while developing on Windows/macOS/Linux
#          (GOOGLE_DESKTOP_CLIENT_ID / _SECRET below).
# 5. The Google Sheet itself must be shared so the signed-in user can edit it
#    (give their Google account Editor access), in addition to being viewable.
# Note: newly created OAuth clients can take a few minutes to start working.
# To go PUBLIC later you must submit the consent screen for verification
# (the spreadsheets scope is "sensitive").
# ----------------------------------------------------------------------------
#
#   SUMBER_DATA = the Google Sheets URL holding the financial report.
#                 Paste the normal browser URL — the app extracts the
#                 spreadsheet ID itself. The sheet must be shared as
#                 "Anyone with the link can view".
SUMBER_DATA=https://docs.google.com/spreadsheets/d/YOUR_SPREADSHEET_ID_HERE

# To enable editing/writing the sheet on DESKTOP (Windows/macOS/Linux), create
# an OAuth client ID of type "Desktop app" in Google Cloud Console (with the
# Google Sheets API enabled) and paste its values here. On Android/iOS this is
# not used — configure the OAuth client via the native platform setup instead.
GOOGLE_DESKTOP_CLIENT_ID=
GOOGLE_DESKTOP_CLIENT_SECRET=

# Android/iOS: the "Web application" OAuth client ID, passed as serverClientId.
# Required by google_sign_in v7 on Android. Also register an "Android" OAuth
# client (your package name + signing SHA-1) in the same Google Cloud project.
GOOGLE_SERVER_CLIENT_ID=
